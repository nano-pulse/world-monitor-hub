{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/**/*.ts": {
      "runtime": "@vercel/node@3.0.0",
      "maxDuration": 15
    }
  },
  "routes": [
    { "src": "/api/(.*)", "continue": true },
    { "handle": "filesystem" },
    { "src": "/((?!api/).*)", "dest": "/index.html" }
  ]
}
